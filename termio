    printf '\n'
    printf "  ${C_BOLD}FLAGS${C_RESET}\n"
    printf "    -v | --verbose    Show background operations (sync, key gen, config writes)\n"
    printf '\n'
    printf "  ${C_BOLD}FEATURES${C_RESET}\n"
