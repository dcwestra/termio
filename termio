    SELECTED_SNIPPET=$(whiptail \
        --title "termio — Snippets" \
        --menu "$_title" "$TH" "$TW" 10 \
        "$@" \
        3>&1 1>&2 2>&3) || { SELECTED_SNIPPET=""; return 1; }
}

# ── Snippet dispatcher ────────────────────────────────────────────────────────

cmd_snip() {
    case "${1:-list}" in
        list|ls)   cmd_snip_list ;;
        add)       cmd_snip_add ;;
        info)      cmd_snip_info "${2:-}" ;;
