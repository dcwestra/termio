wt_test_alias() {
    _alias="$1"
    _host=$(get_field "$_alias" "HostName")
    _user=$(get_field "$_alias" "User")
    _port=$(get_field "$_alias" "Port"); [ -z "$_port" ] && _port="22"
    whiptail --title "termio — Test" \
        --infobox "Testing $_alias (${_user}@${_host}:${_port})..." 5 60
    _start=$(date +%s 2>/dev/null || printf '0')
    if ssh -F "$CONFIG_FILE" \
           -o BatchMode=yes \
           -o ConnectTimeout=8 \
           -o StrictHostKeyChecking=accept-new \
           "$_alias" true 2>/dev/null; then
        _end=$(date +%s 2>/dev/null || printf '0')
