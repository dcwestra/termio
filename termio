# Startup audit check ŌĆö print one-liner warning if keys need rotation (interactive only)
_startup_audit_warn() {
    _threshold=$(pref_get "audit_threshold")
    [ -z "$_threshold" ] && _threshold=90
    _aliases=$(list_aliases)
    [ -z "$_aliases" ] && return 0
    _flagged=0
    while IFS= read -r _a; do
        [ -z "$_a" ] && continue
        _key=$(get_field "$_a" "IdentityFile")
        [ -z "$_key" ] || [ ! -f "$_key" ] && { _flagged=$(( _flagged + 1 )); continue; }
        _kname=$(basename "$_key")
        find "$SSH_DIR" -maxdepth 1 -name "$_kname" -mtime "+${_threshold}" \
            2>/dev/null | grep -q . && _flagged=$(( _flagged + 1 ))
    done <<_EOSW
$(printf '%s\n' "$_aliases")
_EOSW
    if [ "$_flagged" -gt 0 ]; then
        printf "  ${C_YELLOW}ŌÜĀ${C_RESET}  ${C_BOLD}%d key(s) need rotation${C_RESET}  ${C_DIM}(run: termio audit)${C_RESET}\n\n" \
            "$_flagged"
    fi
}

