# ── Command: CONNECT ──────────────────────────────────────────────────────────
# Launches an SSH session directly. Clears the screen beforehand so the
# connection gets a clean terminal, then redraws the banner on return.

cmd_connect() {
    _alias="$1"
    [ -z "$_alias" ] && die "Usage: termio connect <alias>"
    alias_exists "$_alias" || die "Alias \"$_alias\" not found."

    _host=$(get_field "$_alias" "HostName")
    _user=$(get_field "$_alias" "User")
    _port=$(get_field "$_alias" "Port"); [ -z "$_port" ] && _port="22"

    printf '\n'
    info "Connecting to ${C_BOLD}$_alias${C_RESET} (${_user}@${_host}:${_port})"
    printf "  Press ${C_BOLD}Ctrl+D${C_RESET} or type ${C_BOLD}exit${C_RESET} to return to termio.\n\n"

    # Give the user a moment to read, then hand off the terminal cleanly
    sleep 0.4
    clear 2>/dev/null || printf '\033[2J\033[H'

    # Run SSH — passes control of the terminal completely to SSH.
    # set +e so a non-zero exit from SSH (e.g. Ctrl+C) doesn't kill termio.
    set +e
    ssh -F "$CONFIG_FILE" "$_alias"
    _ssh_exit=$?
    set -e

    clear 2>/dev/null || printf '\033[2J\033[H'

    if [ "$_ssh_exit" -ne 0 ] && [ "$_ssh_exit" -ne 130 ]; then
        # 130 = Ctrl+C, not an error worth reporting
        warn "SSH exited with code $_ssh_exit"
    fi
}



