    printf "    %-36s %s\n" "termio       prefer cli"        "Use plain terminal always"
    printf "    %-36s %s\n" "termio [-v] sync"               "Show sync status"
    printf "    %-36s %s\n" "termio [-v] sync init"          "Set up sync folder"
    printf "    %-36s %s\n" "termio [-v] sync detach"        "Detach from sync"
    printf "    %-36s %s\n" "termio [-v] sync keys"          "Key sync status"
    printf "    %-36s %s\n" "termio [-v] sync keys enable"   "Opt in to encrypted key sync"
    printf "    %-36s %s\n" "termio [-v] sync keys disable"  "Remove encrypted archive"
    printf "    %-36s %s\n" "termio [-v] sync keys update"   "Rebuild key archive"
