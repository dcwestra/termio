                        printf "  ${C_BOLD}b)${C_RESET} Back\n\n"
                        cli_prompt "Choice" ""
                        case "$_PROMPT_RESULT" in
                            1|status) cmd_sync_status ;;
                            2|init)   cmd_sync_init ;;
