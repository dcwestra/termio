                                cli_prompt "Alias to bootstrap" ""
                                [ -n "$_PROMPT_RESULT" ] && cmd_bootstrap "$_PROMPT_RESULT" ;;
                            2|connect)
                                cmd_list
                                cli_prompt "Alias for profile session" ""
                                [ -n "$_PROMPT_RESULT" ] && cmd_connect --profile "$_PROMPT_RESULT" ;;
