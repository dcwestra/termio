                        1|whiptail) cmd_prefer whiptail ;;
                        2|cli)      cmd_prefer cli ;;
                        3|auto)     pref_set "ui" ""; success "Preference cleared." ;;
                    esac ;;
                h|help)      cmd_help ;;
                q|quit|exit) break ;;
                *)           warn "Unknown option." ;;
            esac
        done
