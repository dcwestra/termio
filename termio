cmd_add() {
    [ "$HAS_WHIPTAIL" -eq 0 ] && {
        printf '\n  This will:\n'
        printf '    1. Collect connection details\n'
        printf '    2. Generate a unique SSH key\n'
        printf '    3. Copy the public key to the remote (password used once)\n'
        printf '    4. Write a named alias to ~/.ssh/config\n'
        printf "    5. Connect with: ${C_BOLD}ssh <alias>${C_RESET}\n\n"
    }

    wt_input "Alias name (e.g. homeserver, vps-prod)" ""
    while [ -z "$_PROMPT_RESULT" ]; do
        wt_msg "Alias cannot be empty."; wt_input "Alias name" ""
    done
    ALIAS=$(sanitize_alias "$_PROMPT_RESULT")
    [ -z "$ALIAS" ] && die "Alias contains no valid characters."
    info "Using alias: ${C_BOLD}$ALIAS${C_RESET}"

    if alias_exists "$ALIAS"; then
        if wt_yesno "Alias \"$ALIAS\" already exists. Overwrite it?"; then
            remove_config_block "$ALIAS"
            success "Existing alias removed."
        else
            printf '  Aborting.\n'; return 0
        fi
    fi

    wt_input "Short description / note (optional)" ""
    NOTE="$_PROMPT_RESULT"

    wt_input "Group(s) / tags (optional, comma-separated, e.g. homelab,work)" ""
    GROUP="$_PROMPT_RESULT"

    wt_input "Remote hostname or IP address" ""
    while [ -z "$_PROMPT_RESULT" ]; do
        wt_msg "Hostname cannot be empty."; wt_input "Remote hostname or IP" ""
    done
    REMOTE_HOST="$_PROMPT_RESULT"

    wt_input "SSH port" "22"
    REMOTE_PORT="$_PROMPT_RESULT"
    case "$REMOTE_PORT" in ''|*[!0-9]*) REMOTE_PORT=22 ;; esac

    wt_input "Remote username" "$(whoami)"
    while [ -z "$_PROMPT_RESULT" ]; do
        wt_msg "Username cannot be empty."; wt_input "Remote username" "$(whoami)"
    done
    REMOTE_USER="$_PROMPT_RESULT"

    JUMP_HOST=""
    _saved=$(list_aliases)
    if [ -n "$_saved" ]; then
        if wt_yesno "Route through a jump / bastion host?"; then
            if [ "$HAS_WHIPTAIL" -eq 1 ]; then
                wt_pick_alias "Select jump host alias:"; JUMP_HOST="$SELECTED_ALIAS"
            else
                cmd_list
                cli_prompt "Jump host alias (blank = none)" ""; JUMP_HOST="$_PROMPT_RESULT"
            fi
            [ -n "$JUMP_HOST" ] && info "Jump host: ${C_BOLD}$JUMP_HOST${C_RESET}"
        fi
    fi

    wt_password "Remote password"
    REMOTE_PASS="$_PROMPT_RESULT"

    prompt_advanced

    _def_ktype=$(pref_get "key_type"); [ -z "$_def_ktype" ] && _def_ktype="ed25519"
    wt_input "SSH key type (ed25519 / rsa / ecdsa)" "$_def_ktype"
    case "$_PROMPT_RESULT" in
        ed25519|rsa|ecdsa) KEY_TYPE="$_PROMPT_RESULT" ;;
        *) KEY_TYPE="$_def_ktype"
           [ -n "$_PROMPT_RESULT" ] && warn "Unknown key type ŌĆö using $KEY_TYPE" ;;
    esac

    mkdir -p "$SSH_DIR"; chmod 700 "$SSH_DIR"
    KEY_FILE="$SSH_DIR/id_${KEY_TYPE}_${ALIAS}"

    if [ -f "$KEY_FILE" ]; then
        warn "Key already exists ŌĆö reusing: $KEY_FILE"
    else
        info "Generating ${KEY_TYPE} key: $KEY_FILE"
        _keygen "$KEY_FILE" "$KEY_TYPE" "${REMOTE_USER}@${REMOTE_HOST}-${ALIAS}"
        chmod 600 "$KEY_FILE"; chmod 644 "${KEY_FILE}.pub"
        success "Key generated."
    fi

    info "Copying public key to ${REMOTE_USER}@${REMOTE_HOST}:${REMOTE_PORT} ..."
    copy_key_to_remote "$KEY_FILE" "$REMOTE_USER" "$REMOTE_HOST" \
        "$REMOTE_PORT" "$REMOTE_PASS" "$JUMP_HOST"
    unset REMOTE_PASS
    success "Public key copied. Password cleared from memory."

    write_config_block "$ALIAS" "$REMOTE_HOST" "$REMOTE_USER" "$REMOTE_PORT" \
        "$KEY_FILE" "$JUMP_HOST" "$NOTE" "$ADV_ALIVE" "$ADV_FWDAGENT" "$ADV_LOCALFWD" "$GROUP"
    success "Config written."

    sync_auto_export
    sync_keys_update

    printf '\n'
    printf "${C_CYAN}ŌĢöŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢŚ${C_RESET}\n"
    printf "${C_CYAN}ŌĢæ${C_RESET}  ${C_GREEN}${C_BOLD}All done! Ō£ö${C_RESET}                               ${C_CYAN}ŌĢæ${C_RESET}\n"
    printf "${C_CYAN}ŌĢÜŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢØ${C_RESET}\n\n"
